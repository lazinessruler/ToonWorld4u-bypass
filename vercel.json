{
  "version": 2,
  "builds": [
    {
      "src": "api/bypass.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/bypass",
      "dest": "api/bypass.ts"
    },
    {
      "src": "/",
      "dest": "api/bypass.ts"
    },
    {
      "src": "/health",
      "dest": "api/bypass.ts?health=true"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
